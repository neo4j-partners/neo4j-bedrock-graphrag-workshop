# AWS Configuration
AWS_REGION=us-east-1
# Claude 3.5 Sonnet v2 - widely available (default)
# For Claude Sonnet 4: anthropic.claude-sonnet-4-20250514-v1:0
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
AWS_BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
AWS_BEDROCK_AGENT_ID=
AWS_BEDROCK_AGENT_ALIAS_ID=

# Embedding Configuration
# Titan V2 supports 256, 512, or 1024 dimensions (default 1024)
# Note: Azure ada-002 uses 1536 dimensions
EMBEDDING_DIMENSIONS=1024

# Neo4j Configuration
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_VECTOR_INDEX_NAME=chunkEmbeddings
