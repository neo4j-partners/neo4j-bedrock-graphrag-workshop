NEO4J_URI=neo4j+s://xxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Aura Agent (see MCP.md for setup)
AURA_AGENT_ENDPOINT=
AURA_AGENT_CLIENT_ID=
AURA_AGENT_CLIENT_SECRET=
AURA_AGENT_MCP_SERVER=""

# --- Embedding provider (required) ---
# Which provider to use: openai, azure, bedrock
EMBEDDING_PROVIDER=azure

# Embedding vector dimensions (default: 1536 for OpenAI, 1024 for Bedrock Nova)
EMBEDDING_DIMENSIONS=

# --- Option 1: OpenAI directly (https://platform.openai.com/api-keys) ---
OPENAI_API_KEY=

# --- Option 2: Azure AI Foundry (requires az login) ---
AZURE_AI_PROJECT_ENDPOINT=

# --- Option 3: AWS Bedrock (uses AWS credential chain) ---
# AWS_REGION=us-east-1
# EMBEDDING_MODEL_ID=amazon.nova-embed-v1:0

# Model names (defaults work for both OpenAI and Azure)
AZURE_AI_MODEL_NAME=gpt-4o
AZURE_AI_EMBEDDING_NAME=text-embedding-3-small
