# =============================================================================
# Neo4j Connection
# =============================================================================
NEO4J_URI=neo4j+s://xxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# =============================================================================
# Aura Agent (see MCP.md for setup)
# =============================================================================
AURA_AGENT_ENDPOINT=
AURA_AGENT_CLIENT_ID=
AURA_AGENT_CLIENT_SECRET=
AURA_AGENT_MCP_SERVER=""

# =============================================================================
# AWS Bedrock
#   Auth: standard boto3 credential chain (~/.aws/credentials, env vars, IAM role)
#   MODEL_ID and EMBEDDING_MODEL_ID are optional — defaults shown below.
# =============================================================================
AWS_REGION=us-east-1
MODEL_ID=us.anthropic.claude-sonnet-4-6

# --- Embedding model (pick ONE) ---
# Option A: Amazon Nova Multimodal Embeddings - Latest Embedding Model
EMBEDDING_MODEL_ID=amazon.nova-2-multimodal-embeddings-v1:0
EMBEDDING_DIMENSIONS=1024


# Option B: Amazon Titan Text Embeddings V2 (default)
# EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
# EMBEDDING_DIMENSIONS=1024

